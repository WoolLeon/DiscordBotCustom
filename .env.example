# ── Discord ──────────────────────────────
DISCORD_TOKEN=your_discord_bot_token_here
PREFIX=!

# ── Database (MariaDB) ───────────────────
DB_HOST=localhost
DB_USER=your_db_user
DB_PASS=your_db_password
DB_NAME=bot_db

# ── Dashboard ────────────────────────────
DASHBOARD_PORT=3000
DASHBOARD_PASSWORD=change_me
SESSION_SECRET=a_long_random_secret_string

# ── Stream / social announcements ────────
# Twitch live alerts (https://dev.twitch.tv/console/apps)
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
# Poll interval in ms (default 120000)
# ANNOUNCE_POLL_MS=120000

# ── Music (optional Spotify links) ───────
# Create an app at https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
