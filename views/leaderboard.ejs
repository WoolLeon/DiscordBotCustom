<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('partials/head', { accentColor, pageTitle: guildName + ' — Leaderboard' }) %>
    <style>
        .leaderboard-wrap { max-width: 900px; margin: 2rem auto; padding: 0 1rem; }
        .header-card {
            text-align: center; padding: 2rem; margin-bottom: 1.5rem;
            background: var(--card); border: 1px solid var(--card-border); border-radius: 20px;
        }
        .header-card img { width: 88px; height: 88px; border-radius: 50%; border: 3px solid var(--accent); margin-bottom: 1rem; }
        .user-row {
            display: grid; grid-template-columns: 70px 1fr 90px 1fr; gap: 1rem; align-items: center;
            padding: 1rem 1.25rem; border-bottom: 1px solid rgba(255,255,255,0.05);
        }
        .user-row:hover { background: rgba(255,255,255,0.03); }
        .user-avatar { width: 44px; height: 44px; border-radius: 50%; }
        .level-badge {
            background: linear-gradient(135deg, var(--accent), rgba(var(--accent-rgb), 0.7));
            color: #fff; padding: 0.35rem 0.75rem; border-radius: 20px; font-weight: 700; font-size: 0.85rem; text-align: center;
        }
        .progress-fill { height: 6px; background: var(--accent); border-radius: 4px; }
        .progress-track { background: rgba(255,255,255,0.08); border-radius: 4px; height: 6px; }
        @media (max-width: 768px) { .user-row { grid-template-columns: 50px 1fr 80px; } .user-row .xp-col { display: none; } }
    </style>
</head>
<body>
    <div class="leaderboard-wrap">
        <div class="header-card">
            <img src="<%= guildIcon %>" alt="">
            <h1 class="h3 fw-bold mb-1"><%= guildName %></h1>
            <p class="mb-0" style="color:var(--subtext)"><i class="fa-solid fa-trophy text-warning"></i> Activity Leaderboard</p>
        </div>
        <input type="text" id="search" class="form-control mb-3" placeholder="Search members...">
        <div class="glass-card p-0 overflow-hidden">
            <% if (!users.length) { %>
                <p class="text-center py-5" style="color:var(--subtext)">No XP data yet. Start chatting!</p>
            <% } else { %>
                <% users.forEach(u => { %>
                <div class="user-row" data-name="<%= u.name.toLowerCase() %>">
                    <div class="fw-bold text-center">
                        <% if (u.rank === 1) { %>🥇<% } else if (u.rank === 2) { %>🥈<% } else if (u.rank === 3) { %>🥉<% } else { %>#<%= u.rank %><% } %>
                    </div>
                    <div class="d-flex align-items-center gap-2">
                        <img src="<%= u.avatar %>" class="user-avatar" alt="">
                        <span class="fw-semibold"><%= u.name %></span>
                    </div>
                    <div class="level-badge">LV <%= u.level %></div>
                    <div class="xp-col">
                        <div class="small text-end mb-1" style="color:var(--subtext)"><%= u.xpIntoLevel %> / <%= u.reqXp %> XP</div>
                        <div class="progress-track"><div class="progress-fill" style="width:<%= u.progress %>%"></div></div>
                    </div>
                </div>
                <% }) %>
            <% } %>
        </div>
    </div>
    <script>
        const rgb = /^#?([a-f\d]{2})([a-f\d]{2})([a-f\d]{2})$/i.exec('<%= accentColor %>');
        if (rgb) document.documentElement.style.setProperty('--accent-rgb', `${parseInt(rgb[1],16)},${parseInt(rgb[2],16)},${parseInt(rgb[3],16)}`);
        document.getElementById('search')?.addEventListener('input', e => {
            const q = e.target.value.toLowerCase();
            document.querySelectorAll('.user-row').forEach(row => {
                row.style.display = row.dataset.name.includes(q) ? 'grid' : 'none';
            });
        });
    </script>
</body>
</html>
